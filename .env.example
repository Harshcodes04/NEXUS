# Environment Configuration for NEXUS
# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Simulation ────────────────────────────────────────────────────────────────
# Default simulation step size in seconds
SIM_STEP_SECONDS=60

# Auto-simulation interval in milliseconds
SIM_INTERVAL_MS=1000

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite analytics database
DB_PATH=api/data/analytics.db

# ── TLE Import ────────────────────────────────────────────────────────────────
# Cache time-to-live for CelesTrak TLE data (seconds)
TLE_CACHE_TTL=3600

# ── Security ──────────────────────────────────────────────────────────────────
# Secret key for session tokens (change in production!)
SECRET_KEY=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origins (comma-separated, * for all)
ALLOWED_ORIGINS=*
